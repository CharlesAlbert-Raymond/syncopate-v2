# Syncopate local config (per-repo)
# Place as .syncopate.yaml in your repo root.
# Local values override the global config (~/.config/syncopate/config.yaml).

# Directory for worktrees, relative to repo root (default: ".worktrees")
worktree_dir: ".worktrees"

# Script to run inside the tmux session after worktree creation.
# Receives SYNCOPATE_BRANCH and SYNCOPATE_WORKTREE_PATH as env vars.
on_create: "./scripts/setup-worktree.sh"

# Script to run before worktree removal.
# Receives SYNCOPATE_BRANCH and SYNCOPATE_WORKTREE_PATH as env vars.
on_destroy: "./scripts/cleanup-worktree.sh"
