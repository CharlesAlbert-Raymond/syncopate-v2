#!/usr/bin/env bash
# Build the synco binary.
#
# Usage:
#   bin/build            # builds to ./synco
#   bin/build -o /path   # builds to custom path
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
OUTPUT="${1:-${PROJECT_DIR}/synco}"

if [[ "${1:-}" == "-o" ]]; then
    OUTPUT="${2:?usage: bin/build -o <path>}"
    shift 2
fi

echo "Building synco → ${OUTPUT}"
(cd "$PROJECT_DIR" && go build -o "$OUTPUT" .)
echo "Done."
