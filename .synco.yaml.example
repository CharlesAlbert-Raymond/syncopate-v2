# Synco local config (per-repo)
# Place as .synco.yaml in your repo root.
# Local values override the global config (~/.config/synco/config.yaml).

# Directory for worktrees, relative to repo root (default: ".worktrees")
worktree_dir: ".worktrees"

# Script to run inside the tmux session after worktree creation.
# Receives SYNCO_BRANCH and SYNCO_WORKTREE_PATH as env vars.
on_create: "./scripts/setup-worktree.sh"

# Script to run before worktree removal.
# Receives SYNCO_BRANCH and SYNCO_WORKTREE_PATH as env vars.
on_destroy: "./scripts/cleanup-worktree.sh"

# Automatically delete the git branch when removing a worktree (default: false).
# Can be toggled per-deletion in the confirm dialog with 'b'.
auto_delete_branch: false

# Aliases give worktrees a human-friendly display name in the sidebar.
# Map branch names to short labels.
aliases:
  main: "Main"
  feature/my-branch: "My Feature"
